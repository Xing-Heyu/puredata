# ============================================
# 训练数据生成系统 - LLM API 配置（可选）
# ============================================
# 如果你不需要 LLM 增强，可以不配置这个文件，系统会用免费词典 + 本地生成。
# 配置后，中文领域（如"劳动合同"、"医疗"等）的数据质量会大幅提升。
#
# 支持任何 OpenAI 兼容接口，例如：
#   阿里云百炼（千问）: https://dashscope.console.aliyun.com/
#   DeepSeek:           https://platform.deepseek.com/
#   OpenAI:             https://platform.openai.com/
#   本地 Ollama:         http://localhost:11434/v1/chat/completions
# ============================================

# 【必填】你的 API Key
LLM_API_KEY=your_api_key_here

# 【可选】API 地址，默认使用阿里云百炼（千问）
# 换成其他服务时取消注释并修改：
# LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions
# LLM_BASE_URL=https://api.openai.com/v1/chat/completions
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions

# 【可选】模型名，可在 config.json 的 llm.model 中修改
# 默认: qwen-plus
