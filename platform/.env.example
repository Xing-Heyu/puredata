# ==================== PureData 环境配置 ====================
# 复制此文件为 .env 并填写实际值

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ==================== 千问API配置 ====================
# 阿里云千问API密钥（用于高质量数据生成）
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo

# ==================== 安全配置 ====================
# JWT密钥（请生成一个随机字符串）
SECRET_KEY=your_secret_key_here_change_this
# 管理员Token（用于管理员登录）
ADMIN_TOKEN=your_admin_token_here

# ==================== 数据库配置（可选） ====================
# DATABASE_URL=sqlite:///./data/puredata.db
# REDIS_URL=redis://localhost:6379/0

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/puredata.log

# ==================== 生成配置 ====================
# 默认生成质量等级
DEFAULT_QUALITY_LEVEL=high_quality
# 最大并发任务数
MAX_CONCURRENT_TASKS=10
# 数据缓存目录
DATA_CACHE_DIR=./data/cache

# ==================== 备份配置 ====================
# 自动备份间隔（小时）
BACKUP_INTERVAL_HOURS=24
# 最大备份数量
MAX_BACKUPS=30

# ==================== 邮件服务配置 ====================
# 服务商选择: mock(模拟) / smtp(自建) / tencent(腾讯云) / aliyun(阿里云)
EMAIL_PROVIDER=mock

# SMTP配置（自建邮箱）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM_NAME=PureData平台

# ==================== 短信服务配置 ====================
# 服务商选择: mock(模拟) / tencent(腾讯云) / aliyun(阿里云)
SMS_PROVIDER=mock

# 腾讯云配置
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_SMS_APP_ID=your_sms_app_id
TENCENT_SMS_SIGN=your_sign_name
TENCENT_SMS_TEMPLATE_ID=your_template_id

# 阿里云配置
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN=your_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_template_code
