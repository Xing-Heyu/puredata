    "knowledge": {
        "核心概念": {
            "诊断": {
                "正确规则": [
                    "诊断应基于病史、体格检查和辅助检查结果综合判断",
                    "临床诊断需遵循循证医学原则",
                    "疑难病例应进行多学科会诊"
                ],
                "常见错误": {
                    "light": [
                        "凭单一症状下诊断",
                        "诊断名称不规范"
                    ],
                    "medium": [
                        "忽视鉴别诊断",
                        "过度依赖检查结果",
                        "诊断依据不充分"
                    ],
                    "severe": [
                        "凭主观臆断诊断",
                        "故意误诊漏诊",
                        "伪造诊断结果"
                    ]
                }
            },
            "治疗": {
                "正确规则": [
                    "治疗方案应根据诊断结果和患者情况制定",
                    "药物治疗需遵循适应症、禁忌症和用药规范",
                    "手术治疗需充分告知风险并获取知情同意"
                ],
                "常见错误": {
                    "light": [
                        "治疗方案单一化",
                        "忽视患者个体差异"
                    ],
                    "medium": [
                        "过度医疗",
                        "用药剂量不当",
                        "忽视药物相互作用"
                    ],
                    "severe": [
                        "违规开展医疗技术",
                        "使用假劣药品",
                        "无证行医"
                    ]
                }
            },
            "处方": {
                "正确规则": [
                    "处方应由具有处方权的医师开具",
                    "处方内容应包括患者信息、诊断、药品名称、剂量、用法等",
                    "处方药品需符合诊疗规范"
                ],
                "常见错误": {
                    "light": [
                        "处方书写不规范",
                        "剂量单位错误"
                    ],
                    "medium": [
                        "超适应症用药",
                        "处方药品与诊断不符",
                        "忽视配伍禁忌"
                    ],
                    "severe": [
                        "开具麻醉药品用于非医疗目的",
                        "伪造处方",
                        "违规开具精神药品"
                    ]
                }
            },
            "病历": {
                "正确规则": [
                    "病历应客观、真实、准确、及时、完整地记录",
                    "病历书写应符合《病历书写基本规范》",
                    "电子病历应符合《电子病历应用管理规范》"
                ],
                "常见错误": {
                    "light": [
                        "病历书写不及时",
                        "格式不规范"
                    ],
                    "medium": [
                        "病历内容不完整",
                        "涂改病历",
                        "病历归档不及时"
                    ],
                    "severe": [
                        "伪造病历",
                        "销毁病历",
                        "篡改电子病历"
                    ]
                }
            }
        },
        "专科知识": {
            "内科": {
                "正确规则": [
                    "内科疾病诊断应注重病史采集和体格检查",
                    "慢性病管理需长期随访和规范用药",
                    "急危重症应及时识别并转诊"
                ],
                "常见错误": {
                    "medium": [
                        "忽视慢性病的综合管理",
                        "抗生素滥用"
                    ]
                }
            },
            "外科": {
                "正确规则": [
                    "手术前需完善术前评估和知情同意",
                    "手术操作应遵循无菌原则",
                    "术后需密切观察并发症"
                ],
                "常见错误": {
                    "medium": [
                        "术前评估不充分",
                        "手术适应症把握不当"
                    ]
                }
            }
        }
