  "custom_prompt_template": {
    "description": "自定义领域提示词模板",
    "structure": "生成{domain}用户行为序列，包含：{behaviors}等行为，以及合理的转移概率和时间间隔",
    "required_fields": ["domain", "behaviors"],
    "optional_fields": ["attributes", "lifecycle", "time_scale"]
  },
  "generation_config": {
    "default_user_count": 100,
    "default_avg_length": 10,
    "cache_threshold": 5,
    "cache_ttl_days": 30
  }
