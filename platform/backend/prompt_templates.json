{
  "templates": {
    "电商购物": {
      "description": "电商平台用户购物行为序列",
      "prompt": "生成电商用户购物行为序列，包含：浏览、搜索、收藏、加购、下单、支付、收货、评价、复购、退货等行为，以及合理的转移概率和时间间隔",
      "behaviors": ["浏览", "搜索", "收藏", "加购", "下单", "支付", "收货", "评价", "复购", "退货"],
      "attributes": ["amount", "product_id", "rating", "sentiment"],
      "lifecycle": ["新手", "活跃", "稳定", "沉默", "流失", "回归"]
    },
